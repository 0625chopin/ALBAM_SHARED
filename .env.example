# @0625chopin/shared 환경변수 계약(템플릿)
#
# 주의: 이 라이브러리는 이 파일을 "로드하지 않는다".
# 여기 적힌 변수들은 이 라이브러리(src/supabase/*)를 사용하는 소비 앱
# (start-kit-nextjs / albam-admin)의 각 .env.local 에 채워야 하는 값 "목록"이다.
# 실제 값이 든 .env.local 은 각 소비 앱에 두며, 이 폴더에는 두지 않는다.

# 공개 값 — client.ts / server.ts / proxy.ts / admin.ts 공통
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 관리자 전용 — admin.ts (service_role, RLS 우회, 서버에서만 사용)
# 절대 NEXT_PUBLIC_ 접두어를 붙이지 말 것(클라이언트 번들 유출 금지).
SUPABASE_SERVICE_ROLE_KEY=
