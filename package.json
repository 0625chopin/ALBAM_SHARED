{
  "name": "@0625chopin/shared",
  "version": "0.1.10",
  "private": false,
  "description": "알밤마켓 공개 앱·admin 앱 공유 라이브러리 (도메인 타입·Supabase 클라이언트·UI·유틸·디자인 토큰)",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "src"
  ],
  "exports": {
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./database": {
      "types": "./src/database.ts",
      "default": "./src/database.ts"
    },
    "./supabase/client": {
      "types": "./src/supabase/client.ts",
      "default": "./src/supabase/client.ts"
    },
    "./supabase/server": {
      "types": "./src/supabase/server.ts",
      "default": "./src/supabase/server.ts"
    },
    "./supabase/proxy": {
      "types": "./src/supabase/proxy.ts",
      "default": "./src/supabase/proxy.ts"
    },
    "./supabase/storage": {
      "types": "./src/supabase/storage.ts",
      "default": "./src/supabase/storage.ts"
    },
    "./supabase/admin": {
      "types": "./src/supabase/admin.ts",
      "default": "./src/supabase/admin.ts"
    },
    "./format": {
      "types": "./src/format.ts",
      "default": "./src/format.ts"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./src/utils.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./queries/map": {
      "types": "./src/queries/map.ts",
      "default": "./src/queries/map.ts"
    },
    "./ui/*": {
      "types": "./src/ui/*.tsx",
      "default": "./src/ui/*.tsx"
    },
    "./common/*": {
      "types": "./src/common/*.tsx",
      "default": "./src/common/*.tsx"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "check-all": "npm run lint && npm run typecheck && npm run build",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "radix-ui": "^1.6.0",
    "recharts": "^2.15.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.6.0",
    "rimraf": "^6",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8.62.1"
  }
}
